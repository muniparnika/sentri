{
  "source": {
    "include": ["src/"],
    "includePattern": ".+\\.js$"
  },
  "opts": {
    "destination": "./docs-api",
    "recurse": true,
    "readme": "../README.md"
  },
  "plugins": ["plugins/markdown"],
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true,
    "default": {
      "outputSourceFiles": true,
      "includeDate": false
    }
  },
  "tags": {
    "allowUnknownTags": true
  }
}
