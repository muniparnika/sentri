# Sentri — backend environment variables
# Only the vars you need to set are listed here. Everything else has sensible
# defaults. Full reference: docs/guide/env-vars.md

# ─── AI Provider (set at least one) ──────────────────────────────────────────
# Auto-detect order: Anthropic → OpenAI → Google → Ollama
# Force a specific provider: AI_PROVIDER=anthropic | openai | google | local
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── Database (INF-001) ───────────────────────────────────────────────────────
# By default Sentri uses SQLite (data/sentri.db) — no config needed.
# To use PostgreSQL, set DATABASE_URL to a postgres:// connection string:
# DATABASE_URL=postgres://sentri:sentri@localhost:5432/sentri
# PostgreSQL requires: npm install pg pg-native
# Pool size (default 10): PG_POOL_SIZE=10

# ─── Redis (INF-002) ──────────────────────────────────────────────────────────
# Optional. When set, enables Redis-backed rate limiting, token revocation,
# and cross-instance SSE pub/sub. Without Redis, in-memory stores are used.
# REDIS_URL=redis://localhost:6379
# Redis requires: npm install ioredis
# For Redis-backed rate limiting also install: npm install rate-limit-redis

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# CORS_ORIGIN=http://localhost:3000   # Required in production

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
ARTIFACT_SECRET=

# ─── Email (SEC-001 — email verification + future notifications) ──────────────
# Option A: Resend (recommended) — set RESEND_API_KEY
# RESEND_API_KEY=re_xxxxxxxxxxxx
# Option B: SMTP — set SMTP_HOST + SMTP_PORT (+ optional SMTP_USER, SMTP_PASS)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# Sender address for all transactional emails:
# EMAIL_FROM=Sentri <noreply@sentri.dev>
# If neither Resend nor SMTP is configured, emails are logged to console (dev only).
# Skip email verification on registration (dev/CI only — never set in production):
# SKIP_EMAIL_VERIFICATION=true

# ─── BullMQ Job Queue (INF-003) ────────────────────────────────────────────────
# When REDIS_URL is set and `bullmq` is installed, run execution is routed
# through a durable BullMQ queue. Without it, runs execute in-process.
# MAX_WORKERS controls the global concurrency limit for run execution (default 2).
# MAX_WORKERS=2
# Requires: npm install bullmq (and REDIS_URL set above)

# ─── Test Retry (AUTO-005) ────────────────────────────────────────────────────
# Automatic per-test retries before marking a test failed (default 2, max 10).
# Set to 0 to disable retries entirely. No external dependencies.
# NOTE: only the FINAL attempt's video / screenshots / trace are preserved on
# disk — earlier attempts' artifacts are overwritten because each retry
# reuses the same `(runId, stepIndex)` artifact paths. The DB still records
# `retryCount` + `failedAfterRetry` accurately. See the JSDoc on
# `backend/src/runner/retry.js` § "Artifact overwrite behaviour" for details.
# MAX_TEST_RETRIES=2

# ─── SPA Nonce Injection (SEC-002) ─────────────────────────────────────────────
# Path to the Vite-built index.html for CSP nonce injection. Only needed when
# the frontend dist is not at the default location (../frontend/dist/index.html
# relative to the backend source). In Docker multi-container deployments, mount
# the frontend dist into the backend container and set this path.
# SPA_INDEX_PATH=/usr/share/frontend/index.html

# ─── OAuth (optional) ────────────────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/login?provider=google
# APP_URL=http://localhost:3000

# ─── Telemetry (DIF-013) ─────────────────────────────────────────────────────
# Anonymous product telemetry (PostHog).
# Set SENTRI_TELEMETRY=0 or DO_NOT_TRACK=1 to disable fully.
# POSTHOG_API_KEY=phc_xxx
# POSTHOG_HOST=https://us.i.posthog.com
# SENTRI_TELEMETRY=1
# DO_NOT_TRACK=0

# ─── Object Storage (MNT-006) ───────────────────────────────────────────────
# Default (unset/local): artifacts are written to local ./artifacts directory.
# Set STORAGE_BACKEND=s3 to store artifacts in an S3-compatible object store
# (AWS S3, Cloudflare R2, MinIO, etc.).
# STORAGE_BACKEND=s3
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# Optional custom endpoint for S3-compatible providers (R2/MinIO):
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
