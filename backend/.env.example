# ─── AI Provider ──────────────────────────────────────────────────────────────
# Set ONE of these. Sentri auto-detects which key is present.
# Priority order: Anthropic → OpenAI → Google → Ollama (if configured)
#
# You can also force a specific provider with:
#   AI_PROVIDER=anthropic | openai | google | local

# Option 1: Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Option 2: OpenAI GPT-4o-mini (https://platform.openai.com)
OPENAI_API_KEY=

# Option 3: Google Gemini (https://aistudio.google.com/app/apikey — FREE tier)
GOOGLE_API_KEY=

# Option 4: Ollama / Local LLM (FREE — runs on your machine)
#   Requires: https://ollama.ai  →  `ollama pull llama3.2`  →  `ollama serve`
#
#   Set AI_PROVIDER=local to force Ollama even if cloud keys are present.
#   Defaults work out of the box if Ollama is running on localhost.
#
AI_PROVIDER=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# Increase if your machine is slow or the model is large:
# OLLAMA_TIMEOUT_MS=120000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── LLM Retry & Token Limits ────────────────────────────────────────────────
# Retry settings for rate-limited AI API calls (exponential backoff)
LLM_MAX_RETRIES=3
LLM_BASE_DELAY_MS=2000
# Max output tokens per AI call (16384 supports ~10-15 full Playwright tests)
LLM_MAX_TOKENS=16384

# ─── Self-Healing Runtime ─────────────────────────────────────────────────────
# Element finding timeout per strategy in the self-healing waterfall (ms)
HEALING_ELEMENT_TIMEOUT=5000
# Retries per interaction (safeClick / safeFill) before giving up
HEALING_RETRY_COUNT=3
# Pause between retries (ms)
HEALING_RETRY_DELAY=400

# ─── Crawler ──────────────────────────────────────────────────────────────────
# Maximum pages to visit per crawl
CRAWL_MAX_PAGES=30
# Maximum link-follow depth from the start URL
CRAWL_MAX_DEPTH=3
# Timeout (ms) for networkidle wait after page load in snapshots
CRAWL_NETWORKIDLE_TIMEOUT=5000

# ─── Test Execution ──────────────────────────────────────────────────────────
# Run browser without a visible window (set to false for debugging)
BROWSER_HEADLESS=true
# Default viewport size for test runs and crawls
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
# Navigation timeout for page.goto calls (ms)
NAVIGATION_TIMEOUT=30000

# ─── Intent Classifier ───────────────────────────────────────────────────────
# Confidence threshold below which AI-assisted classification kicks in (0-100)
AI_CLASSIFY_THRESHOLD=40

# ─── Logging ──────────────────────────────────────────────────────────────────
# Minimum severity to print: debug | info | warn | error (default: info)
# LOG_LEVEL=info
# Timestamp format: iso (default) | utc | local | epoch
# LOG_DATE_FORMAT=iso
# IANA timezone for "local" format, e.g. America/New_York (default: system)
# LOG_TIMEZONE=
# Emit structured JSON lines on stdout instead of human-readable text
# LOG_JSON=false