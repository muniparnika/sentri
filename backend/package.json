    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "openai": "^4.77.0",
    "playwright": "^1.50.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jsdoc": "^4.0.4"
  }
}
